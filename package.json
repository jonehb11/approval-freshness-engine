{
  "name": "approval-freshness-engine",
  "version": "0.1.0",
  "type": "module",
  "description": "Fail-closed, policy-based PR approval staleness engine. Never approves — only dismisses or no-ops.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:adversarial": "vitest run test/adversarial",
    "eval": "tsx eval/run.ts",
    "p0": "tsx scripts/p0_backfill.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@octokit/rest": "22.0.1",
    "minimatch": "10.2.5",
    "prom-client": "15.1.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "tsx": "4.23.1",
    "@types/node": "26.1.1"
  }
}
